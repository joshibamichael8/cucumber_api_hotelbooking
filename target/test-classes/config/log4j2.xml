<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" packages="com.booking.utilities">

    <Properties>
        <Property name="logPath">./reports/logs/</Property>
        <Property name="logFileName">automation_test.log</Property>
        <Property name="errorFileName">errors.log</Property>
        <Property name="datePattern">yyyy-MM-dd HH:mm:ss</Property>
    </Properties>

    <Appenders>
        <!-- Console Appender -->
        <Console name="Console" target="SYSTEM_OUT">
             <PatternLayout pattern="%d{${datePattern}} [%-5p] %logger{1} - %msg%n" />
        </Console>
        <!-- File Appender for All Logs -->
        <RollingFile name="allLogsFile" fileName="${logPath}${logFileName}" 
                     filePattern="${logPath}${logFileName}.%i.gz">
            <PatternLayout pattern="%d{${datePattern}} [%-5p] %logger{1} - %msg%n" />
            <Policies>
                <SizeBasedTriggeringPolicy size="10 MB" />
            </Policies>
            <DefaultRolloverStrategy max="10" />
        </RollingFile>

        <!-- File Appender for All Logs -->
        <RollingFile name="allLogsFile" fileName="${logPath}${logFileName}" 
                     filePattern="${logPath}${logFileName}.%i.gz">
            <PatternLayout pattern="%d{${datePattern}} [%-5p] %logger{1} - %msg%n" />
            <Policies>
                <SizeBasedTriggeringPolicy size="10 MB" />
            </Policies>
            <DefaultRolloverStrategy max="10" />
        </RollingFile>

        <!-- File Appender for Errors Only -->
        <RollingFile name="errorFile" fileName="${logPath}${errorFileName}" 
                     filePattern="${logPath}${errorFileName}.%i.gz">
            <PatternLayout pattern="%d{${datePattern}} [%-5p] %logger{1} - %msg%n" />
            <Filters>
                <ThresholdFilter level="ERROR" onMatch="ACCEPT" onMismatch="DENY" />
            </Filters>
            <Policies>
                <SizeBasedTriggeringPolicy size="10 MB" />
            </Policies>
            <DefaultRolloverStrategy max="10" />
        </RollingFile>
    </Appenders>

    <Loggers>
        <Logger name="com.booking" level="INFO" />
        <Logger name="org.openqa.selenium" level="ERROR" />
        <Logger name="io.github.bonigarcia" level="INFO" />
        
        <Root level="INFO">
            <AppenderRef ref="console" />
            <AppenderRef ref="allLogsFile" />
            <AppenderRef ref="errorFile" />
        </Root>
    </Loggers>
</Configuration>